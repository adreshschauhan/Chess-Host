generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Player {
  id     Int    @id @default(autoincrement())
  name   String @unique @db.VarChar(100)
  rating Float  @default(500)

  tournamentPlayers TournamentPlayer[]
  matchesAsP1       Match[]            @relation("MatchP1")
  matchesAsP2       Match[]            @relation("MatchP2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tournament {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(100)
  rounds    Int
  active    Boolean @default(true)
  activeKey String? @unique @db.VarChar(16)

  participants TournamentPlayer[]
  roundsList   Round[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model TournamentPlayer {
  id           Int     @id @default(autoincrement())
  tournamentId Int
  playerId     Int
  score        Float   @default(0)
  hadBye       Boolean @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([playerId])
}

model Round {
  id           Int     @id @default(autoincrement())
  tournamentId Int
  roundNumber  Int
  locked       Boolean @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches    Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, roundNumber])
  @@index([tournamentId])
}

model Match {
  id      Int  @id @default(autoincrement())
  roundId Int
  p1Id    Int
  p2Id    Int
  result  Int? // 1=white win, 0=draw, -1=white loss

  round Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  p1    Player @relation("MatchP1", fields: [p1Id], references: [id], onDelete: Cascade)
  p2    Player @relation("MatchP2", fields: [p2Id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roundId])
}
