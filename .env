# Root environment for docker-compose (local/dev)
# Compose automatically loads this file.
HOST_ADDRESS=cpatchessclub.patna.cdac.in
# --- MySQL ---
MYSQL_DATABASE=chess
MYSQL_USER=chess
MYSQL_PASSWORD=chesspass
MYSQL_ROOT_PASSWORD=rootpass

# Host port for MySQL (container is always 3306)
MYSQL_HOST_PORT=3307

# --- Backend ---
BACKEND_PORT=3001
ADMIN_TOKEN=change-me

# Prisma/MySQL connection string used by the backend container
DATABASE_URL=mysql://chess:chesspass@db:3306/chess

# --- Frontend (nginx) ---
FRONTEND_PORT=8080

# Frontend nginx upstream for /api proxy (include scheme)
# Default (compose internal): http://backend:3001
# Examples:
#   BACKEND_URL=http://192.168.1.50:3001
#   BACKEND_URL=http://host.docker.internal:3001
BACKEND_URL=http://backend:3001

# Public URL shown in the UI (Landing → Public access). Set this at deployment.
# Leave empty to auto-detect from the browser (window.location.origin).
# Example: PUBLIC_URL=http://192.168.1.23:8080
PUBLIC_URL=https://cpatchessclub.patna.cdac.in
